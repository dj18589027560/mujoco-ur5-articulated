<mujocoinclude>
    <body name="robot" pos="0.0 0.0 0.0">
        <!-- Ridgeback base visuals -->
        <geom pos="0 0 -0.28" type="mesh" rgba="0.15 0.15 0.15 1" mesh="body-collision" />
        <geom pos="0 0 -0.28" type="mesh" rgba="0.15 0.15 0.15 1" mesh="top" />
        <geom size="0.1 0.2295" pos="0.28 0 0.2295" quat="1 0.0 0 0" type="cylinder" rgba="0.9 0.9 0.9 1" />
        <geom pos="0.28 0 0.456" quat="0.681998 0 0 -0.731354" type="mesh" rgba="0.7 0.7 0.7 1" mesh="ur5_base" />
        <geom size="0.2 0.3 0.3" pos="-0.2 0 0.3" type="box"/>

        <!-- 3-DOF base (Ridgeback) joints -->
        <joint axis="1 0 0" damping="2" name="base_x" pos="0 0 0" type="slide" range="-100 100"/>
        <joint axis="0 1 0" damping="2" name="base_y" pos="0 0 0" type="slide" range="-100 100"/>
        <joint axis="0 0 1" damping="2" name="base_theta" pos="0 0 0" type="hinge" range="-100 100"/>

        <!-- Base plate -->
        <body name="base" pos="0 0 -0.2918">
            <geom type="box" name="base" mass="90" friction="0.4 0.4 0.4" size="0.2 0.2 0.01425" rgba="0. 0. 0. 1" contype="1" conaffinity="1"/>
        </body>

        <!-- === UR5 articulated arm === -->
        <!-- Joint 1: Base rotation (shoulder_pan) - axis in parent (robot) frame -->
        <body name="base_link" pos="0.28 0 0.545159" quat="0.681998 0 0 -0.731354">
            <joint axis="0 0 1" name="shoulder_pan" type="hinge" range="-360 360" damping="2"/>
            <inertial pos="0 0 0" mass="3.7" diaginertia="0.0102675 0.0102675 0.00666" />
            <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="shoulder" />

            <!-- Joint 2: Shoulder lift -->
            <body name="shoulder_link" pos="0 0.13585 0" quat="0.707107 0 0.707107 0">
                <joint axis="0 1 0" name="shoulder_lift" type="hinge" range="-360 360" damping="2"/>
                <inertial pos="0 0 0.28" mass="8.393" diaginertia="0.226891 0.226891 0.0151074" />
                <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="upperarm" />

                <!-- Joint 3: Elbow -->
                <body name="elbow_link" pos="0 -0.1197 0.425">
                    <joint axis="0 1 0" name="elbow" type="hinge" range="-360 360" damping="2"/>
                    <inertial pos="0 0 0.25" mass="2.275" diaginertia="0.0494433 0.0494433 0.004095" />
                    <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="forearm" />

                    <!-- Joint 4: Wrist 1 -->
                    <body name="wrist_1_link" pos="0 0 0.39225" quat="0.707107 0 0.707107 0">
                        <joint axis="0 1 0" name="wrist_1" type="hinge" range="-360 360" damping="2"/>
                        <inertial pos="0 0 0" quat="0.707107 0 0.707107 0" mass="1.219" diaginertia="0.21942 0.111173 0.111173" />
                        <geom type="mesh" rgba="0.7 0.7 0.7 1" mesh="wrist1" />

                        <!-- Joint 5: Wrist 2 -->
                        <body name="wrist_2_link" pos="0 0.093 0">
                            <joint axis="0 0 1" name="wrist_2" type="hinge" range="-360 360" damping="2"/>
                            <inertial pos="0 0 0" quat="0.707107 0 0.707107 0"  mass="1.219" diaginertia="0.21942 0.111173 0.111173" />
                            <geom type="mesh" rgba="0.7 0.7 0.7 1" friction="0.4 0.4 0.4" mesh="wrist2" />

                            <!-- Joint 6: Wrist 3 -->
                            <body name="wrist_3_link" pos="0 0 0.09465">
                                <joint axis="0 1 0" name="wrist_3" type="hinge" range="-360 360" damping="2"/>
                                <inertial pos="0 0 0" quat="0.707107 0 0.707107 0"  mass="0.1879" diaginertia="0.033822 0.0171365 0.0171365" />
                                <geom type="mesh" rgba="0.7 0.7 0.7 1" friction="0.8 0.8 0.8" mesh="wrist3" />

                                <!-- EE link -->
                                <body name="ee_link" pos="0 0.0823 0" quat="0.707107 0 0 0.707107">
                                    <inertial pos="-0.01 0 0" mass="0.001"  diaginertia="1.66667e-08 1.66667e-08 1.66667e-08" />
                                    <geom size="0.005 0.005 0.005" friction="0.8 0.8 0.8" pos="-0.01 0 0" type="box" />

                                    <!-- Robotiq gripper (static mesh) -->
                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>
        </body>
    </body>
</mujocoinclude>
